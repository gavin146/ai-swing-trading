# Used to protect /api/cron/daily-rankings in production.
CRON_SECRET=

# Daily ranking source. Use "mock" for demos or "fmp" after FMP_API_KEY is configured.
AGENT_DATA_SOURCE=mock

# Financial Modeling Prep. Required for /api/agent/daily-rankings?source=fmp.
FMP_API_KEY=

# Federal Reserve Economic Data. Used for rates, inflation, labor, yield curve, and regime scoring.
FRED_API_KEY=

# Bureau of Labor Statistics. Optional; keyless requests work, registered keys expand API limits.
BLS_API_KEY=

# SEC EDGAR direct fallback. No API key is required, but SEC requests should identify the app/contact.
SEC_USER_AGENT=TradePilotAI/1.0 contact=tradestockswithai@gmail.com

# U.S. Treasury Fiscal Data is keyless and free. The app uses exchange-rate data for currency pressure.

# Email alerts. Resend is supported first; without RESEND_API_KEY, email routes return previews.
ALERT_FROM_EMAIL=tradestockswithai@gmail.com
ALERT_TEST_EMAIL=
RESEND_API_KEY=

# Twilio SMS alerts. Use either TWILIO_FROM_NUMBER or TWILIO_MESSAGING_SERVICE_SID.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
ALERT_TEST_PHONE=
ALERT_TEST_CUSTOMER_NAME=

# Future live-data integrations.
OPENAI_API_KEY=
MARKET_DATA_API_KEY=
NEWS_API_KEY=
FINANCIAL_DATA_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
