# App
# Use the final branded production URL after a domain is connected.
# Example: NEXT_PUBLIC_APP_URL=https://www.swingfi.trade
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_API_SECRET=
CRON_SECRET=
AUTH_EMAIL_VERIFICATION_HOURS=24

# Analytics and search
# GA4 example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Google Tag Manager example: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=
# Search Console verification meta tokens for each verified domain.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION_GETSWINGFI=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION_SWINGFI_TRADE=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Newer Supabase dashboards may label keys this way. Use either naming style.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Market and AI
AGENT_DATA_SOURCE=fmp
FMP_API_KEY=
FMP_UNIVERSE_LIMIT=1000
FMP_DETAILED_LIMIT=350
FMP_ENRICHMENT_LIMIT=90
FMP_MIN_SCREENER_ROWS=250
FMP_MIN_DETAILED_CANDIDATES=120
FMP_CANDIDATE_DELAY_MS=150
FMP_CANDIDATE_CONCURRENCY=1
# Temporary testing only. Do not enable for customer-facing production alerts.
DISABLE_MARKET_COVERAGE_GATE=false
# Temporary testing only. Production should use saved Supabase runs, not live UI previews.
ENABLE_LIVE_PREVIEW_FALLBACK=false
FRED_API_KEY=
# Optional. Keyless BLS works with lower limits.
BLS_API_KEY=
OPENAI_API_KEY=

# Email
RESEND_API_KEY=
# Use a branded verified sender before public launch.
# Example: ALERT_FROM_EMAIL=SwingFi <alerts@swingfi.trade>
ALERT_FROM_EMAIL=
ALERT_CUSTOMER_EMAILS=
ADMIN_ALERT_EMAILS=
# Morning emails reuse the saved ranking run if it completed within this window.
MORNING_ALERT_REUSE_WINDOW_MINUTES=180

# SMS alerts
# Use the Twilio account named "Ai swing trading" only.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Use either a purchased Twilio phone number or a Messaging Service SID.
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
ENABLE_TWILIO_MORNING_ALERTS=false
ALERT_TEST_PHONE=
ALERT_TEST_CUSTOMER_NAME=

# Stripe
# Test mode uses pk_test_/sk_test_. Live mode uses pk_live_/sk_live_ plus live Price IDs.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_ENABLED=false
STRIPE_TRIAL_DAYS=30
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=
STRIPE_PORTAL_CONFIGURATION_ID=
# Public SwingFi domains automatically require live keys before checkout unlocks.
# Set true locally when confirming live-mode Stripe keys before launch.
REQUIRE_LIVE_STRIPE=false
